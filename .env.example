# Benchmark endpoint defaults for OpenAI-compatible providers such as RunPod.
# Optional local GWT runtime override. Use hash for offline smoke/no model download.
#GWT_EMBEDDING_PROVIDER=hash
#GWT_EMBEDDING_MODEL=hash
#GWT_EMBEDDING_DIM=384
#GWT_MIN_ACTIVATION=0.2
#GWT_BROADCAST_BUS_MAX_ACCEPTED=4
#GWT_BROADCAST_BUS_THRESHOLD=0.5
#GWT_BROADCAST_BUS_TIMEOUT_SECONDS=0.25
#
# Optional runtime external broadcast subscriber. Keep disabled unless the
# endpoint is intentionally available for live proposal generation.
#GWT_EXTERNAL_SUBSCRIBER_ENABLED=false
#GWT_EXTERNAL_SUBSCRIBER_NAME=external_reasoner
#GWT_EXTERNAL_SUBSCRIBER_API_BASE=https://example-openai-compatible-endpoint/v1
#GWT_EXTERNAL_SUBSCRIBER_MODEL=qwen3.6-35b-a3b
#GWT_EXTERNAL_SUBSCRIBER_API_KEY=test
#GWT_EXTERNAL_SUBSCRIBER_TIMEOUT_SECONDS=10
#GWT_EXTERNAL_SUBSCRIBER_MIN_PRIORITY=0.5

BENCHMARK_API_BASE=https://example-openai-compatible-endpoint/v1
BENCHMARK_API_PATH=/v1
BENCHMARK_MODEL=qwen3.6-35b-a3b
BENCHMARK_API_KEY=test
BENCHMARK_TIMEOUT_SECONDS=30
BENCHMARK_MAX_RETRIES=2
BENCHMARK_CONCURRENCY=16
BENCHMARK_RESULTS_DIR=tests/benchmarks/results
BENCHMARK_ATTEND_BROADCAST_BUS=1
# Optional JSON or CSV format key/value headers, e.g. '{"Authorization":"Bearer ..."}'
#BENCHMARK_API_HEADERS=
